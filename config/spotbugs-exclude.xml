<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
  <!-- Exclude vendor dependency wrappers and auto-generated code -->
  <Match>
    <Package name="~edu\.wpi\..*" />
  </Match>
  <Match>
    <Package name="~com\.ctre\..*" />
  </Match>
  <Match>
    <Package name="~com\.revrobotics\..*" />
  </Match>
  <Match>
    <Package name="~swervelib\..*" />
  </Match>
  <!-- Exclude Main.java (auto-generated entry point) -->
  <Match>
    <Class name="frc.robot.Main" />
  </Match>
  <!--
    EI_EXPOSE_REP2: WPILib Command-Based pattern requires storing subsystem references in
    commands. Defensive copying is impossible — subsystems are shared stateful hardware objects.
    This is intentional architecture throughout frc.robot.
  -->
  <Match>
    <Bug pattern="EI_EXPOSE_REP2" />
  </Match>
  <!--
    EI_EXPOSE_REP: getSwerveDrive() intentionally exposes SwerveDrive for YAGSL advanced ops.
  -->
  <Match>
    <Bug pattern="EI_EXPOSE_REP" />
  </Match>
  <!--
    CN_IDIOM_NO_SUPER_CALL: AdvantageKit @AutoLog annotation processor generates clone()
    without super.clone(). The generated deep-copy creates a fresh instance and copies all
    fields manually — the correct behaviour for LoggableInputs structs. Cannot be suppressed
    at source level since *AutoLogged files are auto-generated and must not be edited.
  -->
  <Match>
    <Bug pattern="CN_IDIOM_NO_SUPER_CALL" />
    <Class name="~.*AutoLogged" />
  </Match>
</FindBugsFilter>
